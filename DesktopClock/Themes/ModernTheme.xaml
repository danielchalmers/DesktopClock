<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Windows 11 Fluent Design theme — context menus and global control defaults.

        Color tokens (WinUI 3 / Fluent 2):
          Accent           #0067C0
          Text/Primary     #1B1B1B
          Text/Secondary   #616161
          Text/Disabled    #A3A3A3
          Fill/Hover       #EBEBEB
          Fill/Pressed     #DEDEDE
          Stroke           #E0E0E0

        ContextMenu popup gets Windows 11 DWM rounded corners automatically.
    -->

    <!-- ===== Context Menu ===== -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="#F9F9F9" />
        <Setter Property="BorderBrush" Value="#E0E0E0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Menu Item ===== -->
    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#1B1B1B" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="ItemBd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Margin="2,1"
                            Padding="10,8,14,8"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Checkmark tick (visible when IsChecked=True) -->
                            <Path x:Name="CheckMark"
                                  Grid.Column="0"
                                  Data="M2,9 L7,14 L14,4"
                                  Stroke="#0067C0"
                                  StrokeThickness="1.8"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Width="16"
                                  Height="16"
                                  Visibility="Collapsed" />

                            <!-- Header / label -->
                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center" />

                            <!-- Keyboard shortcut hint (right-aligned, muted) -->
                            <TextBlock Grid.Column="2"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="#A3A3A3"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0" />

                            <!-- Sub-menu popup (transparent so CornerRadius shows) -->
                            <Popup x:Name="PART_Popup"
                                   Grid.Column="1"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   PopupAnimation="Fade"
                                   VerticalOffset="-6">
                                <Border Background="#F9F9F9"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000"
                                                          Opacity="0.12"
                                                          BlurRadius="16"
                                                          ShadowDepth="4"
                                                          Direction="270" />
                                    </Border.Effect>
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                    SnapsToDevicePixels="True" />
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBd" Property="Background" Value="#EBEBEB" />
                        </Trigger>
                        <!-- Checked state (e.g. "Stay on top") -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#A3A3A3" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Separator ===== -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="#E5E5E5" />
        <Setter Property="Margin" Value="12,4" />
        <Setter Property="Height" Value="1" />
    </Style>

</ResourceDictionary>
