<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Modern UI theme — context menus and shared global styles.
        Sidebar, card, and form control styles live in SettingsWindow.xaml.
    -->

    <!-- ===== Context Menu ===== -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#D8DEE9" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0,5" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Menu Item ===== -->
    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#1E293B" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="ItemBd"
                            Background="{TemplateBinding Background}"
                            Margin="5,1"
                            Padding="10,7,14,7"
                            CornerRadius="5"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Checkmark (SVG tick path) -->
                            <Path x:Name="CheckMark"
                                  Grid.Column="0"
                                  Data="M2,8 L6,12 L13,4"
                                  Stroke="#3B82F6"
                                  StrokeThickness="1.8"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"
                                  Width="15"
                                  Height="15" />

                            <!-- Header content -->
                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center" />

                            <!-- Input gesture hint -->
                            <TextBlock Grid.Column="2"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="#94A3B8"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0" />

                            <!-- Sub-menu popup -->
                            <Popup x:Name="PART_Popup"
                                   Grid.Column="1"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   PopupAnimation="Fade"
                                   VerticalOffset="-6">
                                <Border Background="#FFFFFF"
                                        BorderBrush="#D8DEE9"
                                        BorderThickness="1"
                                        Padding="0,5">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                    SnapsToDevicePixels="True" />
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBd" Property="Background" Value="#EFF6FF" />
                            <Setter Property="Foreground" Value="#1D4ED8" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#94A3B8" />
                        </Trigger>
                        <!-- Checkable item hover: keep blue tick visible -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsHighlighted" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="CheckMark" Property="Stroke" Value="#1D4ED8" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Separator (menu) ===== -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="#E8ECF0" />
        <Setter Property="Margin" Value="10,4" />
        <Setter Property="Height" Value="1" />
    </Style>

</ResourceDictionary>
