<Application x:Class="DesktopClock.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush"
                         Color="#F7F9FC" />
        <SolidColorBrush x:Key="AppSurfaceBrush"
                         Color="#FFFFFF" />
        <SolidColorBrush x:Key="AppSubtleSurfaceBrush"
                         Color="#F3F6FA" />
        <SolidColorBrush x:Key="AppSidebarBrush"
                         Color="#F5F7FA" />
        <SolidColorBrush x:Key="AppBorderBrush"
                         Color="#D8DEE8" />
        <SolidColorBrush x:Key="AppDividerBrush"
                         Color="#E8ECF2" />
        <SolidColorBrush x:Key="AppTextBrush"
                         Color="#1F2328" />
        <SolidColorBrush x:Key="AppSecondaryTextBrush"
                         Color="#5C6470" />
        <SolidColorBrush x:Key="AppAccentBrush"
                         Color="#0067C0" />
        <SolidColorBrush x:Key="AppAccentHoverBrush"
                         Color="#005AA8" />
        <SolidColorBrush x:Key="AppControlHoverBrush"
                         Color="#EEF4FD" />
        <SolidColorBrush x:Key="AppControlPressedBrush"
                         Color="#E3EEFC" />
        <SolidColorBrush x:Key="AppDisabledBrush"
                         Color="#9AA3AF" />

        <Style TargetType="{x:Type Window}">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
        </Style>

        <Style TargetType="{x:Type Slider}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Height="{TemplateBinding MinHeight}"
                              SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="4"
                                                        Background="{StaticResource AppAccentBrush}"
                                                        CornerRadius="2" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="4"
                                                        Background="{StaticResource AppBorderBrush}"
                                                        CornerRadius="2" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14"
                                           Height="14"
                                           Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Ellipse x:Name="ThumbChrome"
                                                         Fill="{StaticResource AppSurfaceBrush}"
                                                         Stroke="{StaticResource AppAccentBrush}"
                                                         StrokeThickness="2" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbChrome" Property="Stroke" Value="{StaticResource AppAccentHoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbChrome" Property="Fill" Value="{StaticResource AppControlPressedBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="MinWidth" Value="184" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                                                  Direction="270"
                                                  Opacity="0.16"
                                                  ShadowDepth="4" />
                            </Border.Effect>
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Margin="0,1">
                                <Grid MinHeight="{TemplateBinding MinHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="16" />
                                    </Grid.ColumnDefinitions>

                                    <Path x:Name="CheckGlyph"
                                          Grid.Column="0"
                                          Width="10"
                                          Height="8"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M 1 4.5 L 4 7.5 L 9 1"
                                          Stroke="{StaticResource AppAccentBrush}"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeThickness="1.8"
                                          Visibility="Collapsed" />

                                    <ContentPresenter x:Name="IconPresenter"
                                                      Grid.Column="0"
                                                      ContentSource="Icon"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True" />

                                    <ContentPresenter Grid.Column="1"
                                                      Margin="{TemplateBinding Padding}"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True" />

                                    <TextBlock Grid.Column="2"
                                               Margin="18,0,8,0"
                                               Foreground="{StaticResource AppSecondaryTextBrush}"
                                               Text="{TemplateBinding InputGestureText}"
                                               VerticalAlignment="Center" />

                                    <Path x:Name="SubmenuArrow"
                                          Grid.Column="3"
                                          Width="5"
                                          Height="8"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 4 4 L 0 8"
                                          Fill="{StaticResource AppSecondaryTextBrush}"
                                          Stretch="Fill"
                                          Visibility="Collapsed" />
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource AppSurfaceBrush}"
                                        BorderBrush="{StaticResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="18"
                                                          Direction="270"
                                                          Opacity="0.16"
                                                          ShadowDepth="4" />
                                    </Border.Effect>
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AppControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AppControlPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                                <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource AppDisabledBrush}" />
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="4,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1"
                                Background="{StaticResource AppDividerBrush}"
                                SnapsToDevicePixels="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
