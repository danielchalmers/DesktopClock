<Window x:Class="DesktopClock.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopClock"
        xmlns:p="clr-namespace:DesktopClock.Properties"
        d:DataContext="{d:DesignInstance Type=local:SettingsWindowViewModel}"
        mc:Ignorable="d"
        Title="Settings"
        Width="{Binding Source={x:Static p:Settings.Default}, Path=SettingsWindowWidth, Mode=TwoWay}"
        Height="{Binding Source={x:Static p:Settings.Default}, Path=SettingsWindowHeight, Mode=TwoWay}"
        MinWidth="1120"
        MinHeight="720"
        ResizeMode="CanResize"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush"
                         Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SoftBrush"
                         Color="#EEF4F9" />
        <SolidColorBrush x:Key="BorderBrush"
                         Color="#D7E3EE" />
        <SolidColorBrush x:Key="MutedTextBrush"
                         Color="#5F7285" />
        <SolidColorBrush x:Key="AccentBrush"
                         Color="#0B678F" />
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style TargetType="Hyperlink">
            <Setter Property="TextDecorations" Value="None" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="PrimaryButton"
               TargetType="Button">
            <Setter Property="Background" Value="#10385B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E7F1F7" />
            <Setter Property="Foreground" Value="#10385B" />
        </Style>

        <Style x:Key="GhostButton"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#10385B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorChipButton"
               TargetType="Button"
               BasedOn="{StaticResource GhostButton}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style x:Key="SectionCardStyle"
               TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>

        <Style x:Key="MiniCardStyle"
               TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SoftBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style x:Key="SectionTitleStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="FieldTitleStyle"
               TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="SectionLeadStyle"
               TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="HintStyle"
               TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style x:Key="ValueTextStyle"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <Style x:Key="PreviewValueStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <ScrollViewer x:Name="SettingsScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      ScrollChanged="SettingsScrollViewer_ScrollChanged"
                      Loaded="SettingsScrollViewer_Loaded">
            <StackPanel x:Name="SettingsContent"
                        Margin="0,0,6,24">
                <Border x:Name="DisplaySection"
                        Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Clock display" />
                        <TextBlock Style="{StaticResource SectionLeadStyle}"
                                   Text="Set what the clock says first. The common path starts with a live sample and a ready-made format, while token-level control stays available when you need it." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="0.75*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource MiniCardStyle}"
                                    Background="#F6FAFD"
                                    Margin="0">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Clock editor" />
                                    <TextBlock Margin="0,4,0,14"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Pick a starting format, check the preview, then tweak the exact text only if needed." />

                                    <Border Padding="16"
                                            Background="White"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource FieldTitleStyle}"
                                                       Text="Live preview" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource PreviewValueStyle}"
                                                       Text="{Binding PreviewTimeText}" />
                                            <TextBlock Style="{StaticResource HintStyle}"
                                                       Text="This sample updates with your format, time zone, and text transform settings." />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Choose a starting point" />
                                    <ComboBox DisplayMemberPath="Example"
                                              ItemsSource="{x:Static local:DateFormatExample.DefaultExamples}"
                                              SelectionChanged="SelectFormat" />
                                    <TextBlock Style="{StaticResource HintStyle}"
                                               Text="Most setups are quickest if you start from an example and make one or two small edits." />

                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Format string" />
                                    <TextBox x:Name="ClockFormatTextBox"
                                             Text="{Binding Settings.Format, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             MaxLines="3" />
                                    <TextBlock Style="{StaticResource HintStyle}"
                                               Text="Mix normal text with date/time tokens in braces. Example: {ddd}, {MMM d}, {h:mm tt}." />
                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Common pieces" />
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Content="Time"
                                                Tag="{}{h:mm tt}"
                                                Click="InsertClockFormatToken_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                        <Button Content="Seconds"
                                                Tag="{}{h:mm:ss tt}"
                                                Click="InsertClockFormatToken_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                        <Button Content="24h"
                                                Tag="{}{HH:mm}"
                                                Click="InsertClockFormatToken_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                        <Button Content="Day"
                                                Tag="{}{ddd}"
                                                Click="InsertClockFormatToken_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                        <Button Content="Date"
                                                Tag="{}{MMM d}"
                                                Click="InsertClockFormatToken_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                        <Button Content="Month"
                                                Tag="{}{MMMM}"
                                                Click="InsertClockFormatToken_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                        <Button Content="Year"
                                                Tag="{}{yyyy}"
                                                Click="InsertClockFormatToken_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                        <Button Content="Zone"
                                                Tag="{}{K}"
                                                Click="InsertClockFormatToken_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                    </WrapPanel>
                                    <TextBlock Margin="0,12,0,0"
                                               Style="{StaticResource HintStyle}"
                                               TextWrapping="Wrap">
                                        <Run Text="Use plain text plus tokens in braces. " />
                                        <Run FontFamily="Consolas"
                                             Text="{}{ddd}, {MMM d}, {h:mm tt}" />
                                        <Run Text=" is one example." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource HintStyle}"
                                               TextWrapping="Wrap">
                                        <Run Text="Text outside braces stays literal. " />
                                        <Run FontFamily="Consolas"
                                             Text="{}Meeting at {h:mm tt}" />
                                        <Run Text=" keeps “Meeting at” as text." />
                                    </TextBlock>
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource HintStyle}">
                                        <Hyperlink NavigateUri="https://learn.microsoft.com/en-us/dotnet/standard/base-types/custom-date-and-time-format-strings"
                                                   RequestNavigate="Hyperlink_RequestNavigate">Date/time formatting rules</Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource MiniCardStyle}"
                                        Background="#F6FAFD"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Display context" />
                                        <TextBlock Margin="0,4,0,14"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="Choose the time zone used for the live clock and its preview." 
                                                   TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource FieldTitleStyle}"
                                                   Text="Displayed time zone" />
                                        <ComboBox ItemsSource="{Binding TimeZones}"
                                                  SelectedItem="{Binding Settings.TimeZoneInfo, Mode=TwoWay}"
                                                  DisplayMemberPath="DisplayName" />
                                        <TextBlock Style="{StaticResource HintStyle}"
                                                   Text="Leave this alone if you just want your local time. Change it for a second-office, travel, or UTC display." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource MiniCardStyle}"
                                        Background="#FFF9F7"
                                        Margin="0">
                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Quick format ideas" />
                                        <TextBlock Margin="0,4,0,12"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="These are simple strings you can paste or build from." />
                                        <TextBlock TextWrapping="Wrap">
                                            <Run FontWeight="SemiBold"
                                                 Text="Short time: " />
                                            <Run FontFamily="Consolas"
                                                 Text="{}{t}" />
                                        </TextBlock>
                                        <TextBlock Margin="0,8,0,0"
                                                   TextWrapping="Wrap">
                                            <Run FontWeight="SemiBold"
                                                 Text="Date + time: " />
                                            <Run FontFamily="Consolas"
                                                 Text="{}{ddd}, {MMM d}, {h:mm tt}" />
                                        </TextBlock>
                                        <TextBlock Margin="0,8,0,0"
                                                   TextWrapping="Wrap">
                                            <Run FontWeight="SemiBold"
                                                 Text="Full precision: " />
                                            <Run FontFamily="Consolas"
                                                 Text="{}{yyyy-MM-dd HH:mm:ss}" />
                                        </TextBlock>
                                        <TextBlock Margin="0,10,0,0"
                                                   Style="{StaticResource HintStyle}">
                                            Standard date/time formats like <Run FontFamily="Consolas" Text="T" /> and <Run FontFamily="Consolas" Text="g" /> also work if you want something even shorter.
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="CountdownSection"
                        Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Countdown &amp; alerts" />
                        <TextBlock Style="{StaticResource SectionLeadStyle}"
                                   Text="Make the target easy to set first, then decide whether you want a custom countdown format or an alert sound. Leaving the format blank keeps the natural wording." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="0.95*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource MiniCardStyle}"
                                    Background="#F6FAFD"
                                    Margin="0">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Countdown editor" />
                                    <TextBlock Margin="0,4,0,14"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Use a preset or choose a date and time. If no date is set, countdown mode stays off." />

                                    <TextBlock Style="{StaticResource FieldTitleStyle}"
                                               Text="Quick presets" />
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Content="+1 hour"
                                                Tag="plus_hour"
                                                Click="ApplyCountdownPreset_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                        <Button Content="Tonight 6 PM"
                                                Tag="tonight"
                                                Click="ApplyCountdownPreset_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                        <Button Content="Tomorrow 9 AM"
                                                Tag="tomorrow_morning"
                                                Click="ApplyCountdownPreset_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                        <Button Content="Next week"
                                                Tag="next_week"
                                                Click="ApplyCountdownPreset_Click"
                                                Style="{StaticResource EditorChipButton}" />
                                    </WrapPanel>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldTitleStyle}"
                                                       Text="Date" />
                                            <DatePicker SelectedDate="{Binding CountdownEditorDate, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldTitleStyle}"
                                                       Text="Hour" />
                                            <ComboBox ItemsSource="{Binding CountdownHours}"
                                                      SelectedItem="{Binding CountdownEditorHour, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat={}{0:00}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Style="{StaticResource FieldTitleStyle}"
                                                       Text="Minute" />
                                            <ComboBox ItemsSource="{Binding CountdownMinutes}"
                                                      SelectedItem="{Binding CountdownEditorMinute, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat={}{0:00}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource HintStyle}"
                                                   Margin="0"
                                                   Text="Leave the date empty to turn countdown mode off." />
                                        <Button Grid.Column="2"
                                                Command="{Binding ResetCountdownCommand}"
                                                Content="Turn off"
                                                Style="{StaticResource GhostButton}" />
                                    </Grid>
                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Exact target value" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Settings.CountdownTo, Mode=TwoWay}" />
                                        <Button Grid.Column="2"
                                                Command="{Binding ResetCountdownCommand}"
                                                Content="Clear"
                                                Style="{StaticResource GhostButton}" />
                                    </Grid>
                                    <TextBlock Style="{StaticResource HintStyle}"
                                               Text="You can type the full value here if you prefer. For most cases, the date and time pickers above are easier." />
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource MiniCardStyle}"
                                        Background="#FFF9F7"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Status &amp; preview" />
                                        <TextBlock Margin="0,4,0,14"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="Confirm the target at a glance, then check how the countdown will read on screen." />
                                        <Border Padding="16"
                                                Background="White"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource FieldTitleStyle}"
                                                           Text="Countdown status" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding CountdownTargetSummary}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,16,0,0"
                                                           Style="{StaticResource FieldTitleStyle}"
                                                           Text="Sample countdown text" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Style="{StaticResource PreviewValueStyle}"
                                                           FontSize="24"
                                                           Text="{Binding PreviewCountdownText}" />
                                                <TextBlock Style="{StaticResource HintStyle}"
                                                           Text="When the countdown is off, the sample still shows how your chosen format would look." />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource MiniCardStyle}"
                                        Background="#FFF9F2"
                                        Margin="0">
                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Sound alerts" />
                                        <TextBlock Margin="0,4,0,14"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="Optional. Use a WAV file if you want the countdown to make a sound when it finishes." />

                                        <CheckBox Content="Play a sound when the countdown ends"
                                                  IsChecked="{Binding Settings.PlaySoundOnCountdown, Mode=TwoWay}" />

                                        <TextBlock Style="{StaticResource FieldTitleStyle}"
                                                   Text="Alert sound file" />
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Settings.WavFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="2"
                                                    Content="Browse..."
                                                    Click="BrowseWavFilePath"
                                                    Style="{StaticResource GhostButton}" />
                                            <Button Grid.Column="4"
                                                    Command="{Binding ResetWavFilePathCommand}"
                                                    Content="Clear"
                                                    Style="{StaticResource GhostButton}" />
                                        </Grid>

                                        <TextBlock Margin="0,16,0,0"
                                                   Style="{StaticResource FieldTitleStyle}"
                                                   Text="Alert repeat interval" />
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Settings.WavFileInterval, Mode=TwoWay}" />
                                            <Button Grid.Column="2"
                                                    Command="{Binding ResetWavFileIntervalCommand}"
                                                    Content="Reset"
                                                    Style="{StaticResource GhostButton}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource MiniCardStyle}"
                                Background="#F7FBFD"
                                Margin="0,16,0,0">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Countdown text" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="Optional. Leave this blank to keep the friendly natural countdown sentence." />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            VerticalAlignment="Top"
                                            Command="{Binding ResetCountdownFormatCommand}"
                                            Content="Use natural wording"
                                            Style="{StaticResource GhostButton}" />
                                </Grid>
                                <TextBlock Margin="0,16,0,0"
                                           Style="{StaticResource FieldTitleStyle}"
                                           Text="Format string" />
                                <TextBox x:Name="CountdownFormatTextBox"
                                         Text="{Binding Settings.CountdownFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         MaxLines="3" />
                                <TextBlock Margin="0,16,0,8"
                                           Style="{StaticResource FieldTitleStyle}"
                                           Text="Common pieces" />
                                <WrapPanel>
                                    <Button Content="HH:MM"
                                            Tag="{}{hh:mm}"
                                            Click="InsertCountdownFormatToken_Click"
                                            Style="{StaticResource EditorChipButton}" />
                                    <Button Content="HH:MM:SS"
                                            Tag="{}{hh:mm:ss}"
                                            Click="InsertCountdownFormatToken_Click"
                                            Style="{StaticResource EditorChipButton}" />
                                    <Button Content="Days"
                                            Tag="{}{dd} days"
                                            Click="InsertCountdownFormatToken_Click"
                                            Style="{StaticResource EditorChipButton}" />
                                    <Button Content="d h m"
                                            Tag="{}{dd}d {hh}h {mm}m"
                                            Click="InsertCountdownFormatToken_Click"
                                            Style="{StaticResource EditorChipButton}" />
                                    <Button Content="Compact"
                                            Tag="c"
                                            Click="InsertCountdownFormatToken_Click"
                                            Style="{StaticResource EditorChipButton}" />
                                </WrapPanel>
                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource HintStyle}"
                                           TextWrapping="Wrap">
                                    <Run Text="Wrap each duration format in braces. " />
                                    <Run FontFamily="Consolas"
                                         Text="{}{hh:mm:ss}" />
                                    <Run Text=" is a common example." />
                                </TextBlock>
                                <TextBlock Style="{StaticResource HintStyle}"
                                           TextWrapping="Wrap">
                                    <Run Text="No escaping needed. " />
                                    <Run FontFamily="Consolas"
                                         Text="{}{dd} days {hh:mm:ss}" />
                                    <Run Text=" is valid." />
                                </TextBlock>
                                <TextBlock Style="{StaticResource HintStyle}"
                                           TextWrapping="Wrap">
                                    <Run Text="Text outside braces stays literal. Leave it blank for the natural countdown sentence." />
                                </TextBlock>
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource HintStyle}">
                                    <Hyperlink NavigateUri="https://learn.microsoft.com/en-us/dotnet/standard/base-types/custom-timespan-format-strings"
                                               RequestNavigate="Hyperlink_RequestNavigate">Countdown formatting rules</Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="AppearanceSection"
                        Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Appearance" />
                        <TextBlock Style="{StaticResource SectionLeadStyle}"
                                   Text="Set the clock text first, then the surface behind it. Background images and outline tuning stay available, but they no longer crowd the main text controls." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="0.9*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource MiniCardStyle}"
                                    Background="#F7FBFD"
                                    Margin="0">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Clock text" />
                                    <TextBlock Margin="0,4,0,14"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Choose the typeface and text color first. Those are the settings most people adjust most often." />

                                    <Border Padding="16"
                                            Background="White"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource FieldTitleStyle}"
                                                       Text="Sample text" />
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="30"
                                                       Text="{Binding PreviewTimeText}"
                                                       TextWrapping="Wrap"
                                                       FontFamily="{Binding Settings.FontFamily}"
                                                       FontStyle="{Binding Settings.FontStyle}"
                                                       FontWeight="{Binding Settings.FontWeight}">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding Settings.TextColor, Mode=OneWay}"
                                                                     Opacity="{Binding Settings.TextOpacity}" />
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource HintStyle}"
                                                       Text="This preview reflects the current font, casing, and text color settings." />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Font family" />
                                    <ComboBox ItemsSource="{Binding FontFamilies}"
                                              SelectedItem="{Binding Settings.FontFamily, Mode=TwoWay}" />

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldTitleStyle}"
                                                       Text="Font style" />
                                            <ComboBox ItemsSource="{Binding FontStyles}"
                                                      SelectedItem="{Binding Settings.FontStyle, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldTitleStyle}"
                                                       Text="Font weight" />
                                            <ComboBox ItemsSource="{Binding FontWeights}"
                                                      SelectedItem="{Binding Settings.FontWeight, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Text transform" />
                                    <ComboBox ItemsSource="{Binding TextTransforms}"
                                              SelectedItem="{Binding Settings.TextTransform, Mode=TwoWay}" />

                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Text color" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="26"
                                                Height="26"
                                                VerticalAlignment="Center"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Settings.TextColor, Mode=OneWay}" />
                                            </Border.Background>
                                        </Border>
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding Settings.TextColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="4"
                                                Content="Pick..."
                                                Click="PickTextColor"
                                                Style="{StaticResource GhostButton}" />
                                    </Grid>

                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Text opacity" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="52" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0"
                                                Value="{Binding Settings.TextOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="0"
                                                Maximum="1"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="True" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Settings.TextOpacity, StringFormat=0.00}"
                                                   Style="{StaticResource ValueTextStyle}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource MiniCardStyle}"
                                    Background="#FFF9F7"
                                    Margin="0">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Clock surface" />
                                    <TextBlock Margin="0,4,0,14"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Choose whether the clock sits on a filled surface or appears as outlined text, then adjust the finishing details." />

                                    <TextBlock Style="{StaticResource FieldTitleStyle}"
                                               Text="Background or outline color" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="26"
                                                Height="26"
                                                VerticalAlignment="Center"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Settings.OuterColor, Mode=OneWay}" />
                                            </Border.Background>
                                        </Border>
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding Settings.OuterColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="4"
                                                Content="Pick..."
                                                Click="PickOuterColor"
                                                Style="{StaticResource GhostButton}" />
                                    </Grid>

                                    <CheckBox Margin="0,16,0,0"
                                              Content="Use a solid background fill"
                                              IsChecked="{Binding Settings.BackgroundEnabled, Mode=TwoWay}" />
                                    <TextBlock Style="{StaticResource HintStyle}"
                                               Text="Turn this off if you want the clock to appear as outlined text without a filled panel behind it." />

                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Surface opacity" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="52" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0"
                                                Value="{Binding Settings.BackgroundOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="0"
                                                Maximum="1"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="True" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Settings.BackgroundOpacity, StringFormat=0.00}"
                                                   Style="{StaticResource ValueTextStyle}" />
                                    </Grid>

                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Corner roundness" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="52" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0"
                                                Value="{Binding Settings.BackgroundCornerRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="0"
                                                Maximum="24"
                                                TickFrequency="0.1"
                                                IsSnapToTickEnabled="True" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Settings.BackgroundCornerRadius, StringFormat=0.0}"
                                                   Style="{StaticResource ValueTextStyle}" />
                                    </Grid>

                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Outline thickness" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="52" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0"
                                                Value="{Binding Settings.OutlineThickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="0"
                                                Maximum="5"
                                                TickFrequency="0.1"
                                                IsSnapToTickEnabled="True" />
                                    <TextBlock Grid.Column="1"
                                                   Text="{Binding Settings.OutlineThickness, StringFormat=0.0}"
                                                   Style="{StaticResource ValueTextStyle}" />
                                    </Grid>
                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Background image" />
                                    <TextBlock Style="{StaticResource HintStyle}"
                                               Text="Optional. Leave this empty if you want to use only a solid fill or outline color." />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Settings.BackgroundImagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="2"
                                                Content="Browse..."
                                                Click="BrowseBackgroundImagePath"
                                                Style="{StaticResource GhostButton}" />
                                        <Button Grid.Column="4"
                                                Command="{Binding ResetBackgroundImagePathCommand}"
                                                Content="Clear"
                                                Style="{StaticResource GhostButton}" />
                                    </Grid>

                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource FieldTitleStyle}"
                                               Text="Image fit" />
                                    <ComboBox ItemsSource="{Binding ImageStretches}"
                                              SelectedItem="{Binding Settings.BackgroundImageStretch, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="WindowSection"
                        Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Window behavior" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource MiniCardStyle}"
                                    Background="#F6FAFD"
                                    Margin="0">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Startup &amp; visibility" />
                                    <TextBlock Margin="0,4,0,14"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Control where the clock appears when Windows and the app start." />
                                    <CheckBox Content="Launch automatically when I sign in"
                                              IsChecked="{Binding Settings.RunOnStartup, Mode=TwoWay}" />
                                    <CheckBox Content="Start with the clock hidden"
                                              IsChecked="{Binding Settings.StartHidden, Mode=TwoWay}" />
                                    <CheckBox Content="Show the clock in the taskbar"
                                              IsChecked="{Binding Settings.ShowInTaskbar, Mode=TwoWay}" />
                                    <CheckBox Content="Hide the clock from Alt+Tab"
                                              IsChecked="{Binding Settings.HideFromAltTab, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource MiniCardStyle}"
                                    Background="#FFF9F7"
                                    Margin="0">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Interaction" />
                                    <TextBlock Margin="0,4,0,14"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Tune how the clock behaves when it shares space with other apps." />
                                    <CheckBox Content="Keep the clock above other windows"
                                              IsChecked="{Binding Settings.Topmost, Mode=TwoWay}" />
                                    <CheckBox Content="Pass clicks through to windows behind"
                                              IsChecked="{Binding Settings.ClickThrough, Mode=TwoWay}" />
                                    <CheckBox Content="Allow dragging the clock"
                                              IsChecked="{Binding Settings.DragToMove, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4"
                                    Style="{StaticResource MiniCardStyle}"
                                    Background="#F8FBF7"
                                    Margin="0">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Protection &amp; layout" />
                                    <TextBlock Margin="0,4,0,14"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Useful for overlays, OLED displays, or dynamic text widths." />
                                    <CheckBox Content="Keep the right edge fixed as text changes"
                                              IsChecked="{Binding Settings.RightAligned, Mode=TwoWay}" />
                                    <CheckBox Content="Shift the clock slightly to reduce burn-in"
                                              IsChecked="{Binding Settings.BurnInMitigation, Mode=TwoWay}" />
                                    <CheckBox Content="Hide the clock while fullscreen apps are open"
                                              IsChecked="{Binding Settings.HideWhenFullscreen, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="ToolsSection"
                        Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Tools &amp; help" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource MiniCardStyle}"
                                    Margin="0">
                                <StackPanel>
                                    <Button Content="Open settings folder"
                                            Click="OpenSettingsFolder"
                                            IsEnabled="{x:Static p:Settings.CanBeSaved}"
                                            Style="{StaticResource GhostButton}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource HintStyle}"
                                               Text="Open the folder where the JSON settings file is stored." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource MiniCardStyle}"
                                    Margin="0">
                                <StackPanel>
                                    <Button Content="Open settings file"
                                            Click="OpenSettingsFile"
                                            IsEnabled="{x:Static p:Settings.CanBeSaved}"
                                            Style="{StaticResource GhostButton}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource HintStyle}"
                                               Text="Open the JSON settings file for advanced edits." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4"
                                    Style="{StaticResource MiniCardStyle}"
                                    Margin="0">
                                <StackPanel>
                                    <Button Content="Create new clock"
                                            Click="CreateNewClock"
                                            IsEnabled="{x:Static p:Settings.CanBeSaved}"
                                            Style="{StaticResource GhostButton}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource HintStyle}"
                                               Text="Copy this clock and launch it with a new settings file." />
                                </StackPanel>
                            </Border>

                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1.1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource MiniCardStyle}"
                                    Margin="0">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Shortcuts" />
                                    <TextBlock><Run FontWeight="SemiBold">Right-click:</Run><Run Text=" open the menu" /></TextBlock>
                                    <TextBlock Margin="0,6,0,0"><Run FontWeight="SemiBold">Double-click:</Run><Run Text=" copy the displayed text" /></TextBlock>
                                    <TextBlock Margin="0,6,0,0"><Run FontWeight="SemiBold">Drag:</Run><Run Text=" move the clock" /></TextBlock>
                                    <TextBlock Margin="0,6,0,0"><Run FontWeight="SemiBold">Ctrl + Scroll:</Run><Run Text=" change the size" /></TextBlock>
                                    <TextBlock Margin="0,6,0,0"><Run FontWeight="SemiBold">Ctrl + + / -:</Run><Run Text=" resize from the keyboard" /></TextBlock>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource MiniCardStyle}"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Links" />
                                        <WrapPanel Margin="0,12,0,0">
                                            <Border Style="{StaticResource MiniCardStyle}"
                                                    Width="220"
                                                    Margin="0,0,10,10">
                                                <StackPanel>
                                                    <TextBlock>
                                                        <Hyperlink NavigateUri="https://play.google.com/store/apps/details?id=com.danielchalmers.journalapp"
                                                                   RequestNavigate="Hyperlink_RequestNavigate">Good Diary</Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,8,0,0"
                                                               Style="{StaticResource HintStyle}"
                                                               Text="Stay on top of your well-being (Android)." />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource MiniCardStyle}"
                                                    Width="220"
                                                    Margin="0,0,10,10">
                                                <StackPanel>
                                                    <TextBlock>
                                                        <Hyperlink NavigateUri="https://github.com/danielchalmers/Network-Monitor"
                                                                   RequestNavigate="Hyperlink_RequestNavigate">Network Monitor</Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,8,0,0"
                                                               Style="{StaticResource HintStyle}"
                                                               Text="See latency and bandwidth usage (Windows)." />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource MiniCardStyle}"
                                                    Width="220"
                                                    Margin="0,0,10,10">
                                                <StackPanel>
                                                    <TextBlock>
                                                        <Hyperlink NavigateUri="https://github.com/danielchalmers/SentryReplay"
                                                                   RequestNavigate="Hyperlink_RequestNavigate">Sentry Replay</Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,8,0,0"
                                                               Style="{StaticResource HintStyle}"
                                                               Text="Watch your Tesla dashcam clips (Windows)." />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource MiniCardStyle}"
                                                    Width="220"
                                                    Margin="0,0,10,10">
                                                <StackPanel>
                                                    <TextBlock>
                                                        <Hyperlink NavigateUri="https://github.com/danielchalmers/RadialActions"
                                                                   RequestNavigate="Hyperlink_RequestNavigate">Radial Actions</Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,8,0,0"
                                                               Style="{StaticResource HintStyle}"
                                                               Text="Summon a customizable radial menu (Windows)." />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource MiniCardStyle}"
                                                    Width="220"
                                                    Margin="0,0,10,10">
                                                <StackPanel>
                                                    <TextBlock>
                                                        <Hyperlink NavigateUri="https://github.com/danielchalmers"
                                                                   RequestNavigate="Hyperlink_RequestNavigate">All my projects on GitHub</Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,8,0,0"
                                                               Style="{StaticResource HintStyle}"
                                                               Text="Browse the rest of the project catalog." />
                                                </StackPanel>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource MiniCardStyle}"
                                        Margin="0">
                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Credits" />
                                        <WrapPanel Margin="0,12,0,0">
                                            <TextBlock Margin="0,0,16,8"><Hyperlink NavigateUri="https://github.com/CommunityToolkit/dotnet" RequestNavigate="Hyperlink_RequestNavigate">CommunityToolkit</Hyperlink></TextBlock>
                                            <TextBlock Margin="0,0,16,8"><Hyperlink NavigateUri="https://github.com/Fody/Costura" RequestNavigate="Hyperlink_RequestNavigate">Costura.Fody</Hyperlink></TextBlock>
                                            <TextBlock Margin="0,0,16,8"><Hyperlink NavigateUri="https://github.com/HavenDV/H.NotifyIcon" RequestNavigate="Hyperlink_RequestNavigate">H.NotifyIcon.Wpf</Hyperlink></TextBlock>
                                            <TextBlock Margin="0,0,16,8"><Hyperlink NavigateUri="https://github.com/Humanizr/Humanizer" RequestNavigate="Hyperlink_RequestNavigate">Humanizer</Hyperlink></TextBlock>
                                            <TextBlock Margin="0,0,16,8"><Hyperlink NavigateUri="https://www.newtonsoft.com/json" RequestNavigate="Hyperlink_RequestNavigate">Newtonsoft.Json</Hyperlink></TextBlock>
                                            <TextBlock Margin="0,0,16,8"><Hyperlink NavigateUri="https://github.com/Fody/PropertyChanged" RequestNavigate="Hyperlink_RequestNavigate">PropertyChanged.Fody</Hyperlink></TextBlock>
                                            <TextBlock Margin="0,0,16,8"><Hyperlink NavigateUri="https://github.com/danielchalmers/WpfWindowPlacement" RequestNavigate="Hyperlink_RequestNavigate">WpfWindowPlacement</Hyperlink></TextBlock>
                                            <TextBlock Margin="0,0,16,8"><Hyperlink NavigateUri="https://icon.kitchen/i/H4sIAAAAAAAAA0WP2grCMAyG3yXe7sIDCO5WH0DQOxHJ2rQrdstsOw%2BI725aB%2FaiCV8O%2F5833NGPFKF%2Bg8ZwPbbUEdQGfaQKjN16N2BIuRxJAmgyOPoEFTjFvQBUimK8JCdznzLCnoMUZqY86Wz%2BbLnYrM2qsEOLg0hBvI0uKE8Cjd2j1q63WS%2FxAPViXkFwthXpnDacEne%2F3JMptIgeX2WXmuwWRM9seLctalODDagd9Slb7ViPPp9%2BAux1YKfzVRzlf1AD588XVKijiB0BAAA%3D" RequestNavigate="Hyperlink_RequestNavigate">IconKitchen</Hyperlink></TextBlock>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
