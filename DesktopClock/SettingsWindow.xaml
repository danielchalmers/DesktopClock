<Window x:Class="DesktopClock.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopClock"
        xmlns:p="clr-namespace:DesktopClock.Properties"
        d:DataContext="{d:DesignInstance Type=local:SettingsWindowViewModel}"
        mc:Ignorable="d"
        Title="Settings"
        Width="{Binding Source={x:Static p:Settings.Default}, Path=SettingsWindowWidth, Mode=TwoWay}"
        Height="{Binding Source={x:Static p:Settings.Default}, Path=SettingsWindowHeight, Mode=TwoWay}"
        MinWidth="720"
        MinHeight="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderBrush" Value="#D0D0D0" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="CardGroupBox"
               TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <StackPanel>
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True" />
                            <ContentPresenter />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBodyPanel"
               TargetType="StackPanel">
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="WrapSectionPanel"
               TargetType="WrapPanel">
            <Setter Property="Orientation" Value="Horizontal" />
        </Style>

        <Style x:Key="WrapCardBorder"
               TargetType="Border">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Width" Value="220" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderBrush" Value="#DCDCDC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#FAFAFA" />
        </Style>

        <Style x:Key="WideWrapCardBorder"
               TargetType="Border"
               BasedOn="{StaticResource WrapCardBorder}">
            <Setter Property="Width" Value="344" />
        </Style>

        <Style x:Key="CompactWrapCardBorder"
               TargetType="Border"
               BasedOn="{StaticResource WrapCardBorder}">
            <Setter Property="Width" Value="180" />
        </Style>

        <Style x:Key="ControlRow"
               TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="LabelTextBlock"
               TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="DescriptionTextBlock"
               TargetType="TextBlock">
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SliderValueTextBlock"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style TargetType="Hyperlink">
            <Setter Property="TextDecorations" Value="None" />
        </Style>
    </Window.Resources>

    <ScrollViewer x:Name="SettingsScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  ScrollChanged="SettingsScrollViewer_ScrollChanged"
                  Loaded="SettingsScrollViewer_Loaded">
        <StackPanel Margin="12">
            <GroupBox Header="Clock"
                      Style="{StaticResource CardGroupBox}">
                <StackPanel Style="{StaticResource CardBodyPanel}">
                    <WrapPanel Style="{StaticResource WrapSectionPanel}">
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Clock text format"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Settings.Format, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             MaxLines="3" />
                                    <ComboBox Grid.Column="1"
                                             DisplayMemberPath="Example"
                                             ItemsSource="{x:Static local:DateFormatExample.DefaultExamples}"
                                             SelectionChanged="SelectFormat" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Displayed time zone"
                                           Style="{StaticResource LabelTextBlock}" />
                                <ComboBox ItemsSource="{Binding TimeZones}"
                                          SelectedItem="{Binding Settings.TimeZoneInfo, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Countdown"
                      Style="{StaticResource CardGroupBox}">
                <StackPanel Style="{StaticResource CardBodyPanel}">
                    <WrapPanel Style="{StaticResource WrapSectionPanel}">
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Countdown target date and time"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Settings.CountdownTo, Mode=TwoWay}" />
                                    <Button Grid.Column="2"
                                            Content="Reset"
                                            Command="{Binding ResetCountdownCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Countdown display format"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Settings.CountdownFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             MaxLines="3" />
                                    <Button Grid.Column="2"
                                            Content="Reset"
                                            Command="{Binding ResetCountdownFormatCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Alerts"
                      Style="{StaticResource CardGroupBox}">
                <StackPanel Style="{StaticResource CardBodyPanel}">
                    <WrapPanel Style="{StaticResource WrapSectionPanel}">
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Countdown sound"
                                           Style="{StaticResource LabelTextBlock}" />
                                <TextBlock Text="Alert sound file"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Settings.WavFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2"
                                            Content="Browse..."
                                            Click="BrowseWavFilePath" />
                                    <Button Grid.Column="4"
                                            Content="Reset"
                                            Command="{Binding ResetWavFilePathCommand}" />
                                </Grid>
                                <TextBlock Text="Alert repeat interval"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Settings.WavFileInterval, Mode=TwoWay}" />
                                    <Button Grid.Column="2"
                                            Content="Reset"
                                            Command="{Binding ResetWavFileIntervalCommand}" />
                                </Grid>
                                <CheckBox Content="Play this sound when the countdown ends"
                                          IsChecked="{Binding Settings.PlaySoundOnCountdown, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Window"
                      Style="{StaticResource CardGroupBox}">
                <StackPanel Style="{StaticResource CardBodyPanel}">
                    <WrapPanel Style="{StaticResource WrapSectionPanel}">
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Startup &amp; visibility"
                                           Style="{StaticResource LabelTextBlock}" />
                                <CheckBox Content="Launch automatically when I sign in"
                                          IsChecked="{Binding Settings.RunOnStartup, Mode=TwoWay}" />
                                <CheckBox Content="Start with the clock hidden"
                                          IsChecked="{Binding Settings.StartHidden, Mode=TwoWay}" />
                                <CheckBox Content="Show the clock in the taskbar"
                                          IsChecked="{Binding Settings.ShowInTaskbar, Mode=TwoWay}" />
                                <CheckBox Content="Hide the clock from Alt+Tab"
                                          IsChecked="{Binding Settings.HideFromAltTab, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Interaction"
                                           Style="{StaticResource LabelTextBlock}" />
                                <CheckBox Content="Keep the clock above other windows"
                                          IsChecked="{Binding Settings.Topmost, Mode=TwoWay}" />
                                <CheckBox Content="Let clicks pass through to windows behind"
                                          IsChecked="{Binding Settings.ClickThrough, Mode=TwoWay}" />
                                <CheckBox Content="Allow dragging the clock with the mouse"
                                          IsChecked="{Binding Settings.DragToMove, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Layout &amp; protection"
                                           Style="{StaticResource LabelTextBlock}" />
                                <CheckBox Content="Keep the right edge fixed as text length changes"
                                          IsChecked="{Binding Settings.RightAligned, Mode=TwoWay}" />
                                <CheckBox Content="Gently move the clock to reduce burn-in risk"
                                          IsChecked="{Binding Settings.BurnInMitigation, Mode=TwoWay}" />
                                <CheckBox Content="Hide the clock while fullscreen apps are active"
                                          IsChecked="{Binding Settings.HideWhenFullscreen, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Text"
                      Style="{StaticResource CardGroupBox}">
                <StackPanel Style="{StaticResource CardBodyPanel}">
                    <WrapPanel Style="{StaticResource WrapSectionPanel}">
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Font"
                                           Style="{StaticResource LabelTextBlock}" />
                                <TextBlock Text="Font family"
                                           Style="{StaticResource LabelTextBlock}" />
                                <ComboBox ItemsSource="{Binding FontFamilies}"
                                          SelectedItem="{Binding Settings.FontFamily, Mode=TwoWay}" />
                                <TextBlock Text="Font style"
                                           Style="{StaticResource LabelTextBlock}" />
                                <ComboBox ItemsSource="{Binding FontStyles}"
                                          SelectedItem="{Binding Settings.FontStyle, Mode=TwoWay}" />
                                <TextBlock Text="Font weight"
                                           Style="{StaticResource LabelTextBlock}" />
                                <ComboBox ItemsSource="{Binding FontWeights}"
                                          SelectedItem="{Binding Settings.FontWeight, Mode=TwoWay}" />
                                <TextBlock Text="Text capitalization"
                                           Style="{StaticResource LabelTextBlock}" />
                                <ComboBox ItemsSource="{Binding TextTransforms}"
                                          SelectedItem="{Binding Settings.TextTransform, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Color &amp; opacity"
                                           Style="{StaticResource LabelTextBlock}" />
                                <TextBlock Text="Text color"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Settings.TextColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2"
                                            Content="Pick..."
                                            Click="PickTextColor" />
                                </Grid>
                                <TextBlock Text="Text opacity"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0"
                                            Margin="0"
                                            Value="{Binding Settings.TextOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.01"
                                            IsSnapToTickEnabled="True" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Settings.TextOpacity, StringFormat=0.00}"
                                               Style="{StaticResource SliderValueTextBlock}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Background"
                      Style="{StaticResource CardGroupBox}">
                <StackPanel Style="{StaticResource CardBodyPanel}">
                    <WrapPanel Style="{StaticResource WrapSectionPanel}">
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Fill"
                                           Style="{StaticResource LabelTextBlock}" />
                                <TextBlock Text="Background or outline color"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Settings.OuterColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2"
                                            Content="Pick..."
                                            Click="PickOuterColor" />
                                </Grid>
                                <CheckBox Content="Use a solid background fill"
                                          IsChecked="{Binding Settings.BackgroundEnabled, Mode=TwoWay}" />
                                <TextBlock Text="Background opacity"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0"
                                            Margin="0"
                                            Value="{Binding Settings.BackgroundOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.01"
                                            IsSnapToTickEnabled="True" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Settings.BackgroundOpacity, StringFormat=0.00}"
                                               Style="{StaticResource SliderValueTextBlock}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Shape and outline"
                                           Style="{StaticResource LabelTextBlock}" />
                                <TextBlock Text="Background corner roundness"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0"
                                            Margin="0"
                                            Value="{Binding Settings.BackgroundCornerRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Minimum="0"
                                            Maximum="24"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="True" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Settings.BackgroundCornerRadius, StringFormat=00.0}"
                                               Style="{StaticResource SliderValueTextBlock}" />
                                </Grid>
                                <TextBlock Text="Outline thickness"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0"
                                            Margin="0"
                                            Value="{Binding Settings.OutlineThickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Minimum="0"
                                            Maximum="5"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="True" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Settings.OutlineThickness, StringFormat=0.0}"
                                               Style="{StaticResource SliderValueTextBlock}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource WideWrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Background image"
                                           Style="{StaticResource LabelTextBlock}" />
                                <Grid Style="{StaticResource ControlRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Settings.BackgroundImagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2"
                                            Content="Browse..."
                                            Click="BrowseBackgroundImagePath" />
                                    <Button Grid.Column="4"
                                            Content="Reset"
                                            Command="{Binding ResetBackgroundImagePathCommand}" />
                                </Grid>
                                <TextBlock Text="Background image fit"
                                           Style="{StaticResource LabelTextBlock}" />
                                <ComboBox ItemsSource="{Binding ImageStretches}"
                                          SelectedItem="{Binding Settings.BackgroundImageStretch, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Tools"
                      Style="{StaticResource CardGroupBox}">
                <StackPanel Style="{StaticResource CardBodyPanel}">
                    <WrapPanel Style="{StaticResource WrapSectionPanel}">
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <Button Content="Open settings folder"
                                        Click="OpenSettingsFolder"
                                        IsEnabled="{x:Static p:Settings.CanBeSaved}" />
                                <TextBlock Text="Open the folder where the settings file is stored."
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <Button Content="Open settings file"
                                        Click="OpenSettingsFile"
                                        IsEnabled="{x:Static p:Settings.CanBeSaved}" />
                                <TextBlock Text="Open the JSON settings file in Notepad."
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <Button Content="Create new clock"
                                        Click="CreateNewClock"
                                        IsEnabled="{x:Static p:Settings.CanBeSaved}" />
                                <TextBlock Text="Copy this clock and start it with fresh settings."
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Shortcuts"
                      Style="{StaticResource CardGroupBox}">
                <StackPanel Style="{StaticResource CardBodyPanel}">
                    <WrapPanel Style="{StaticResource WrapSectionPanel}">
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Right-click"
                                           Style="{StaticResource LabelTextBlock}" />
                                <TextBlock Text="Open the menu"
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Double-click"
                                           Style="{StaticResource LabelTextBlock}" />
                                <TextBlock Text="Copy the displayed text"
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Drag"
                                           Style="{StaticResource LabelTextBlock}" />
                                <TextBlock Text="Move the clock"
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Ctrl + Scroll"
                                           Style="{StaticResource LabelTextBlock}" />
                                <TextBlock Text="Change the size"
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Ctrl + +"
                                           Style="{StaticResource LabelTextBlock}" />
                                <TextBlock Text="Increase the size"
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock Text="Ctrl + -"
                                           Style="{StaticResource LabelTextBlock}" />
                                <TextBlock Text="Decrease the size"
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Links"
                      Style="{StaticResource CardGroupBox}">
                <StackPanel Style="{StaticResource CardBodyPanel}">
                    <WrapPanel Style="{StaticResource WrapSectionPanel}">
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock>
                                    <Hyperlink NavigateUri="https://play.google.com/store/apps/details?id=com.danielchalmers.journalapp"
                                               RequestNavigate="Hyperlink_RequestNavigate">
                                        Good Diary
                                    </Hyperlink>
                                </TextBlock>
                                <TextBlock Text="Stay on top of your well-being (Android)"
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock>
                                    <Hyperlink NavigateUri="https://github.com/danielchalmers/Network-Monitor"
                                               RequestNavigate="Hyperlink_RequestNavigate">
                                        Network Monitor
                                    </Hyperlink>
                                </TextBlock>
                                <TextBlock Text="See latency and bandwidth usage (Windows)"
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock>
                                    <Hyperlink NavigateUri="https://github.com/danielchalmers/SentryReplay"
                                               RequestNavigate="Hyperlink_RequestNavigate">
                                        Sentry Replay
                                    </Hyperlink>
                                </TextBlock>
                                <TextBlock Text="Watch your Tesla dashcam clips (Windows)"
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock>
                                    <Hyperlink NavigateUri="https://github.com/danielchalmers/RadialActions"
                                               RequestNavigate="Hyperlink_RequestNavigate">
                                        Radial Actions
                                    </Hyperlink>
                                </TextBlock>
                                <TextBlock Text="Summon a customizable radial menu (Windows)"
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                        <Border
                                Style="{StaticResource WrapCardBorder}">
                            <StackPanel>
                                <TextBlock>
                                    <Hyperlink NavigateUri="https://github.com/danielchalmers"
                                               RequestNavigate="Hyperlink_RequestNavigate">
                                        All my projects on GitHub
                                    </Hyperlink>
                                </TextBlock>
                                <TextBlock Text="Browse the rest of my apps and tools."
                                           Style="{StaticResource DescriptionTextBlock}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Credits"
                      Style="{StaticResource CardGroupBox}">
                <StackPanel Style="{StaticResource CardBodyPanel}">
                    <WrapPanel Style="{StaticResource WrapSectionPanel}">
                        <Border
                                Style="{StaticResource CompactWrapCardBorder}">
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/CommunityToolkit/dotnet"
                                           RequestNavigate="Hyperlink_RequestNavigate">
                                    CommunityToolkit
                                </Hyperlink>
                            </TextBlock>
                        </Border>
                        <Border
                                Style="{StaticResource CompactWrapCardBorder}">
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/Fody/Costura"
                                           RequestNavigate="Hyperlink_RequestNavigate">
                                    Costura.Fody
                                </Hyperlink>
                            </TextBlock>
                        </Border>
                        <Border
                                Style="{StaticResource CompactWrapCardBorder}">
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/HavenDV/H.NotifyIcon"
                                           RequestNavigate="Hyperlink_RequestNavigate">
                                    H.NotifyIcon.Wpf
